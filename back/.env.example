# Copiez ce fichier en `.env` puis renseignez vos valeurs.
#   cp back/.env.example back/.env

# === MONGODB ===
MONGODB_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/michelin_catalog?authSource=admin

# === AUTH ===
# Au moins 32 caractères, générée aléatoirement en production.
JWT_SECRET=change_me_super_secret_at_least_32_chars

# === SERVEUR ===
PORT=3000
# Origine(s) autorisée(s) par CORS (séparées par des virgules).
CORS_ORIGIN=https://ton-frontend.vercel.app
