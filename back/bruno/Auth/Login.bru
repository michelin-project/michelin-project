meta {
  name: Login
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/auth/login
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "email": "marc@example.com",
    "password": "secret123"
  }
}

script:post-response {
  if (res.body && res.body.access_token) {
    bru.setVar("access_token", res.body.access_token);
  }
}
